{
    "robot": "nero",
    "firmeware_version": "default",
    "comm": {
        "type": "can",
        "can": {
            "channel": "can0",
            "interface": "socketcan",
            "bitrate": 1000000,
            "enable_check_can": true,
            "auto_connect": true,
            "timeout": 0.001,
            "local_loopback": false,
            "receive_own_messages": false
        }
    },
    "log": {
        "level": "INFO",
        "path": ""
    },
    "auto_set_motion_mode": true,
    "enable_joint_limits": true,
    "joint_names": [
        "joint1",
        "joint2",
        "joint3",
        "joint4",
        "joint5",
        "joint6",
        "joint7"
    ],
    "joint_limits": {
        "joint1": [-2.705261, 2.705261],
        "joint2": [-1.74533, 1.74533],
        "joint3": [-2.757621, 2.757621],
        "joint4": [-1.012291, 2.146755],
        "joint5": [-2.757621, 2.757621],
        "joint6": [-0.733039, 0.959932],
        "joint7": [-1.570797, 1.570797]
    }
}
